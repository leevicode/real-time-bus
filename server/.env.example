# ============================================
# Waltti Open Data API Authentication
# ============================================

# Obtain these by registering at https://opendata.waltti.fi
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# The actual API key used in requests is the Base64 encoding of "CLIENT_ID:CLIENT_SECRET"
# You can generate it with this Linux/macOS command:
#   echo -n "${CLIENT_ID}:${CLIENT_SECRET}" | base64
API_KEY=base64-encoded-client-id-and-secret
